  </div>

<script>
  // ---- Countdown ----
  const tripDate = new Date('2026-07-03T08:00:00');
  const cdEl = document.getElementById('countdown');
  const cdDays = document.getElementById('cdDays');
  const cdHours = document.getElementById('cdHours');
  const cdMins = document.getElementById('cdMins');
  const cdSecs = document.getElementById('cdSecs');

  function pad(n){ return String(n).padStart(2,'0'); }

  function updateCountdown(){
    const now = new Date();
    const diff = tripDate - now;
    if(diff <= 0){
      cdEl.classList.add('expired');
      document.querySelector('.countdown-label').textContent = "It's trip day!";
      cdDays.textContent = '00';
      cdHours.textContent = '00';
      cdMins.textContent = '00';
      cdSecs.textContent = '00';
      return;
    }
    const days = Math.floor(diff / (1000*60*60*24));
    const hours = Math.floor((diff / (1000*60*60)) % 24);
    const mins = Math.floor((diff / (1000*60)) % 60);
    const secs = Math.floor((diff / 1000) % 60);
    cdDays.textContent = pad(days);
    cdHours.textContent = pad(hours);
    cdMins.textContent = pad(mins);
    cdSecs.textContent = pad(secs);
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // ---- Form ----
  const form = document.getElementById('regForm');
  const submitBtn = document.getElementById('submitBtn');
  const interestField = document.getElementById('interestField');
  const paidField = document.getElementById('paidField');
  const paydayField = document.getElementById('paydayField');
  const payDateInput = document.getElementById('payDate');

  const fields = {
    fullName: { el: document.getElementById('fullName'), wrap: document.getElementById('nameField'), validate: v => v.trim().length >= 2 },
    location: { el: document.getElementById('location'), wrap: document.getElementById('locField'), validate: v => v.trim().length >= 2 },
    phone: { el: document.getElementById('phone'), wrap: document.getElementById('phoneField'), validate: v => v.replace(/[^0-9]/g,'').length >= 9 }
  };

  function clearError(key){
    fields[key].wrap.classList.remove('invalid');
  }
  Object.keys(fields).forEach(k => {
    fields[k].el.addEventListener('input', () => clearError(k));
  });

  // Choice buttons (interest / paid)
  let selections = { interest: null, paid: null };

  document.querySelectorAll('.choice-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.dataset.group;
      const value = btn.dataset.value;
      selections[group] = value;

      document.querySelectorAll(`.choice-btn[data-group="${group}"]`).forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');

      if(group === 'interest'){
        interestField.classList.remove('invalid');
      }
      if(group === 'paid'){
        paidField.classList.remove('invalid');
        if(value === 'no'){
          paydayField.classList.add('show');
        } else {
          paydayField.classList.remove('show');
          paydayField.classList.remove('invalid');
          payDateInput.value = '';
        }
      }
    });
  });

  payDateInput.addEventListener('input', () => paydayField.classList.remove('invalid'));

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    let valid = true;

    Object.keys(fields).forEach(k => {
      const f = fields[k];
      if(!f.validate(f.el.value)){
        f.wrap.classList.add('invalid');
        valid = false;
      } else {
        f.wrap.classList.remove('invalid');
      }
    });

    if(!selections.interest){
      interestField.classList.add('invalid');
      valid = false;
    }
    if(!selections.paid){
      paidField.classList.add('invalid');
      valid = false;
    }
    if(selections.paid === 'no' && !payDateInput.value){
      paydayField.classList.add('invalid');
      valid = false;
    }

    if(!valid) return;

    const entry = {
      name: fields.fullName.el.value.trim(),
      location: fields.location.el.value.trim(),
      phone: fields.phone.el.value.trim(),
      interested: selections.interest === 'yes' ? 'Yes' : 'No',
      paid: selections.paid === 'yes' ? 'Yes' : 'No',
      payDate: selections.paid === 'no' ? payDateInput.value : null
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Opening WhatsApp…';

    let msg = `Hi! Here's my response for the Ocean Green Beach Resort trip (3rd July).\n`;
    msg += `Name: ${entry.name}\n`;
    msg += `Location: ${entry.location}\n`;
    msg += `Phone: ${entry.phone}\n`;
    msg += `Still interested: ${entry.interested}\n`;
    msg += `Paid: ${entry.paid}\n`;
    if(entry.payDate){
      msg += `Will pay on: ${entry.payDate} (deadline 25th June, 2026)\n`;
    }

    const waText = encodeURIComponent(msg);
    window.open(`https://wa.me/233542165661?text=${waText}`, '_blank', 'noopener');

    submitBtn.disabled = false;
    submitBtn.textContent = 'Reserve My Spot →';
    form.reset();
    selections = { interest: null, paid: null };
    document.querySelectorAll('.choice-btn').forEach(b => b.classList.remove('selected'));
    paydayField.classList.remove('show');
  });
</script>

