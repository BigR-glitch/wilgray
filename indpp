<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ocean Green Beach Resort — Trip Registration</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Caveat:wght@600&family=DM+Sans:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
  :root{
    --ocean-deep:#073a42;
    --ocean-mid:#0e5c68;
    --coral:#ff5a36;
    --red:#c8252b;
    --gold:#f4b942;
    --cream:#fff8e9;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    font-family:'DM Sans',sans-serif;
    background:
      radial-gradient(ellipse 900px 500px at 50% -10%, rgba(244,185,66,0.35), transparent 60%),
      linear-gradient(180deg, var(--ocean-deep) 0%, var(--ocean-mid) 55%, #0a4750 100%);
    min-height:100vh;
    color:var(--cream);
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:32px 16px 56px;
    position:relative;
    overflow-x:hidden;
  }
  body::before, body::after{
    content:"";
    position:absolute;
    width:260px; height:260px;
    background:radial-gradient(circle, rgba(255,255,255,0.06), transparent 70%);
    border-radius:50%;
    pointer-events:none;
  }
  body::before{ top:-60px; left:-80px; }
  body::after{ bottom:10%; right:-100px; }

.wrap{ width:100%; max-width:480px; position:relative; z-index:1; }

/* –– HERO –– */
.eyebrow{
text-align:center;
letter-spacing:0.35em;
font-size:12px;
font-weight:700;
color:var(–gold);
margin-bottom:6px;
opacity:0;
animation:riseIn .6s ease forwards;
}
.presents{
text-align:center;
font-family:‘Caveat’,cursive;
font-size:22px;
color:rgba(255,248,233,0.75);
margin:0 0 6px;
opacity:0;
animation:riseIn .6s .08s ease forwards;
}
h1{
font-family:‘Anton’,sans-serif;
text-transform:uppercase;
text-align:center;
font-size:clamp(34px,9vw,48px);
line-height:0.95;
margin:0 0 14px;
letter-spacing:0.01em;
background:linear-gradient(180deg,#fff 0%, var(–gold) 100%);
-webkit-background-clip:text;
background-clip:text;
color:transparent;
text-shadow:0 4px 0 rgba(200,37,43,0.35);
opacity:0;
animation:riseIn .6s .16s ease forwards;
}
.meta-row{
display:flex;
justify-content:center;
gap:10px;
flex-wrap:wrap;
margin-bottom:28px;
opacity:0;
animation:riseIn .6s .26s ease forwards;
}
.meta-pill{
background:rgba(255,248,233,0.1);
border:1px solid rgba(244,185,66,0.4);
border-radius:999px;
padding:7px 16px;
font-size:13px;
font-weight:700;
color:var(–cream);
display:flex;
align-items:center;
gap:6px;
}
.meta-pill b{ color:var(–gold); }

.countdown{
text-align:center;
margin-bottom:28px;
opacity:0;
animation:riseIn .6s .3s ease forwards;
}
.countdown-label{
font-size:11px;
letter-spacing:0.18em;
text-transform:uppercase;
color:rgba(255,248,233,0.55);
margin-bottom:10px;
font-weight:700;
}
.countdown-units{
display:flex;
justify-content:center;
gap:10px;
}
.cd-unit{
background:rgba(255,248,233,0.08);
border:1px solid rgba(244,185,66,0.35);
border-radius:12px;
padding:10px 14px;
min-width:58px;
display:flex;
flex-direction:column;
align-items:center;
}
.cd-num{
font-family:‘Anton’,sans-serif;
font-size:22px;
color:var(–gold);
line-height:1;
}
.cd-tag{
font-size:10px;
letter-spacing:0.08em;
text-transform:uppercase;
color:rgba(255,248,233,0.55);
margin-top:4px;
font-weight:600;
}
.countdown.expired .countdown-label{ color:var(–coral); }
.countdown.expired .cd-num{ color:var(–coral); }

@keyframes riseIn{
from{ opacity:0; transform:translateY(10px); }
to{ opacity:1; transform:translateY(0); }
}

/* –– TICKET CARD –– */
.ticket-stage{ perspective:1400px; }
.ticket{
position:relative;
background:var(–cream);
color:var(–ocean-deep);
border-radius:18px;
box-shadow:0 24px 50px -16px rgba(0,0,0,0.55);
overflow:hidden;
opacity:0;
animation:riseIn .6s .34s ease forwards;
}
.ticket-top{
background:linear-gradient(135deg, var(–coral), var(–red));
padding:18px 22px;
display:flex;
justify-content:space-between;
align-items:center;
}
.ticket-top .label{
font-family:‘Anton’,sans-serif;
letter-spacing:0.05em;
font-size:18px;
color:#fff;
text-transform:uppercase;
}
.ticket-top .tag{
font-size:11px;
font-weight:700;
color:rgba(255,255,255,0.85);
border:1.5px solid rgba(255,255,255,0.7);
border-radius:6px;
padding:3px 8px;
letter-spacing:0.06em;
}

.perforation{
position:relative;
height:0;
border-top:2px dashed rgba(7,58,66,0.25);
margin:0 18px;
}
.perforation::before, .perforation::after{
content:””;
position:absolute;
top:-12px;
width:24px; height:24px;
background:var(–ocean-deep);
border-radius:50%;
}
.perforation::before{ left:-30px; }
.perforation::after{ right:-30px; }

.ticket-body{ padding:24px 22px 22px; }

.field{ margin-bottom:16px; }
.field label{
display:block;
font-size:12px;
font-weight:700;
letter-spacing:0.06em;
text-transform:uppercase;
color:var(–ocean-mid);
margin-bottom:6px;
}
.field input{
width:100%;
border:2px solid rgba(14,92,104,0.18);
background:#fffdf6;
border-radius:10px;
padding:13px 14px;
font-size:15px;
font-family:‘DM Sans’,sans-serif;
color:var(–ocean-deep);
outline:none;
transition:border-color .15s ease, box-shadow .15s ease;
}
.field input::placeholder{ color:rgba(7,58,66,0.35); }
.field input:focus{
border-color:var(–coral);
box-shadow:0 0 0 4px rgba(255,90,54,0.14);
}
.field .err{
display:none;
font-size:12px;
color:var(–red);
font-weight:700;
margin-top:5px;
}
.field.invalid input{ border-color:var(–red); }
.field.invalid .err{ display:block; }

.choice-row{
display:flex;
gap:10px;
}
.choice-btn{
flex:1;
border:2px solid rgba(14,92,104,0.18);
background:#fffdf6;
border-radius:10px;
padding:12px 10px;
font-family:‘DM Sans’,sans-serif;
font-size:14px;
font-weight:700;
color:var(–ocean-mid);
cursor:pointer;
transition:border-color .15s ease, background .15s ease, color .15s ease, transform .1s ease;
}
.choice-btn:hover{ transform:translateY(-1px); }
.choice-btn.selected{
border-color:var(–coral);
background:linear-gradient(135deg, var(–coral), var(–red));
color:#fff;
}
.field.invalid .choice-btn{ border-color:var(–red); }

.payday-box{
display:none;
background:rgba(244,185,66,0.1);
border:1.5px dashed var(–gold);
border-radius:12px;
padding:14px 16px 16px;
}
.payday-box.show{ display:block; }
.payday-box label{ color:var(–ocean-deep); }
.payday-box input{
width:100%;
border:2px solid rgba(14,92,104,0.18);
background:#fffdf6;
border-radius:10px;
padding:12px 14px;
font-size:15px;
font-family:‘DM Sans’,sans-serif;
color:var(–ocean-deep);
outline:none;
}
.payday-box input:focus{
border-color:var(–coral);
box-shadow:0 0 0 4px rgba(255,90,54,0.14);
}
.payday-note{
font-size:12px;
color:var(–red);
font-weight:700;
margin-top:8px;
line-height:1.4;
}

.submit-btn{
width:100%;
border:none;
border-radius:12px;
background:linear-gradient(135deg, var(–coral), var(–red));
color:#fff;
font-family:‘Anton’,sans-serif;
letter-spacing:0.04em;
text-transform:uppercase;
font-size:17px;
padding:15px;
cursor:pointer;
margin-top:6px;
box-shadow:0 10px 24px -8px rgba(200,37,43,0.6);
transition:transform .12s ease, box-shadow .12s ease, opacity .2s ease;
}
.submit-btn:hover{ transform:translateY(-2px); box-shadow:0 14px 28px -8px rgba(200,37,43,0.7); }
.submit-btn:active{ transform:translateY(0); }
.submit-btn:disabled{ opacity:0.6; cursor:not-allowed; transform:none; }

.ticket-foot{
text-align:center;
font-size:11px;
color:rgba(7,58,66,0.55);
padding:10px 22px 18px;
font-weight:500;
}

/* footer */
.footer-note{
text-align:center;
font-size:12px;
color:rgba(255,248,233,0.55);
margin-top:22px;
line-height:1.6;
}

@media (prefers-reduced-motion: reduce){
*{ animation-duration:0.01ms !important; animation-iteration-count:1 !important; }
}
</style>

</head>
